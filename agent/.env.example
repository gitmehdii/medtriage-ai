APP_NAME=MedTriageAI Agent
APP_ENV=local

# LLM provider: ollama, gemini, or none
LLM_PROVIDER=none
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# External modules owned by other tracks. Leave empty to run with graceful fallbacks.
VISION_SERVICE_URL=
ML_SERVICE_URL=

REQUEST_TIMEOUT_SECONDS=15
