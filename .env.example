# === Vision Service ===
AZURE_VISION_KEY=your_azure_vision_key
AZURE_VISION_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com

# === ML Model (Azure Container Instances) ===
AZURE_ML_SERVICE_URL=http://medtriage-ml-model.westeurope.azurecontainer.io:8002

# === Agent ===
LLM_PROVIDER=gemini        # ollama | gemini | none
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# === Medical Knowledge MCP (non-secret configuration) ===
# Docker Compose configures the agent with http://medical-knowledge:8003.
MEDICAL_KNOWLEDGE_PORT=8003
MEDICAL_KNOWLEDGE_FRESHNESS_DAYS=365
MEDICAL_KNOWLEDGE_FALLBACK_TIMEOUT_SECONDS=5
# Leave empty to disable official-source fallback until domains are reviewed.
MEDICAL_KNOWLEDGE_FALLBACK_BASE_URLS=
